{
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "plugins": ["@prettier/plugin-ruby", "prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": ["*.md", "*.markdown"],
      "options": {
        "proseWrap": "preserve",
        "printWidth": 80
      }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": { "tabWidth": 2, "singleQuote": false }
    },
    {
      "files": ["*.html", "*.liquid"],
      "options": { "parser": "html" }
    },
    {
      "files": ["*.scss", "*.css"],
      "options": { "singleQuote": false }
    },
    {
      "files": ["*.rb"],
      "options": { "tabWidth": 2 }
    }
  ]
}
